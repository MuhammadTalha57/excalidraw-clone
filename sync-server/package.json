{
  "name": "sync-server",
  "version": "1.0.0",
  "description": "Real-time collaboration server for excalidraw-clone (Express + Socket.IO + MongoDB)",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.5.0",
    "nanoid": "^5.0.7",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.10",
    "@types/socket.io": "^3.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
