{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/socket.ts": { "maxDuration": 300   }
  },
  "rewrites": [
    { "source": "/api/socket/(.*)", "destination": "/api/socket" },
    { "source": "/api/sessions", "destination": "/api/socket" },
    { "source": "/api/sessions/(.*)", "destination": "/api/socket" }
  ]
}